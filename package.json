{
  "name": "clean-react",
  "version": "1.0.1",
  "type": "module",
  "description": "NodeJs Rest API using TDD, Clean Architecture and Typescript",
  "author": "Francisco dos Passos",
  "homepage": "https://fordevs-react.herokuapp.com",
  "license": "GNU GPL3",
  "scripts": {
    "start": "webpack-dev-server --open",
    "lint": "eslint 'src/**'",
    "lint:fix": "npm run lint -- --fix",
    "dev:base": "webpack-dev-server --config webpack.dev.js",
    "dev": "npm run dev:base -- --open",
    "build": "webpack --config webpack.config.js",
    "test": "jest --passWithNoTests --no-cache --runInBand",
    "test:watch": "npm test -- --watch",
    "test:staged": "npm test -- --findRelatedTests",
    "test:ci": "npm test -- --coverage",
    "test:coveralls": "cat coverage/lcov.info | coveralls",  
    "test:cypress": "cypress open",
    "test:cypress:run": "cypress run",
    "test:cypress:ci": "start-server-and-test dev:base http-get://localhost:8080 test:cypress:run",
    "check": "npm-check -u -s",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^12.1.5",
    "@types/faker": "^4.1.11",
    "@types/jest": "^27.0.1",
    "@types/node": "^16.9.1",
    "@types/react": "^17.0.21",
    "@types/react-dom": "^17.0.9",
    "@types/react-router-dom": "^5.1.5",
    "@typescript-eslint/experimental-utils": "^4.31.1",
    "clean-webpack-plugin": "^4.0.0",
    "coveralls": "^3.1.1",
    "css-loader": "^6.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-cypress": "^2.11.1",
    "eslint-plugin-es": "^4.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.37.5",
    "faker": "^4.1.0",
    "git-commit-msg-linter": "^3.3.3",
    "globals": "^17.5.0",
    "husky": "^7.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.2.0",
    "jest-localstorage-mock": "^2.4.26",
    "lint-staged": "^11.1.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^3.3.3",
    "ts-jest": "^27.0.5",
    "ts-loader": "^9.5.1",
    "typescript": "^4.0.3",
    "typescript-eslint": "^8.58.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "axios": "^0.21.4",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^5.2.0"
  }
}
